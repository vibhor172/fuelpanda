            "url": { "raw": "{{base_url}}/api/v1/locations", "host": ["{{base_url}}"], "path": ["api", "v1", "locations"] },
            "description": "Create a HUB or TERMINAL. `type` must be `HUB` or `TERMINAL`. latitude/longitude optional."
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"name\": \"Central Hub\",\n  \"type\": \"HUB\",\n  \"address\": \"100 Refinery Rd\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.006\n}" },
                "url": { "raw": "{{base_url}}/api/v1/locations", "host": ["{{base_url}}"], "path": ["api", "v1", "locations"] }
              },
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"created_at\": \"2026-06-10T09:00:00Z\",\n  \"updated_at\": \"2026-06-10T09:00:00Z\",\n  \"name\": \"Central Hub\",\n  \"type\": \"HUB\",\n  \"address\": \"100 Refinery Rd\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.006\n}"
            }
          ]
        },
