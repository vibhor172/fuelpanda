    {
      "name": "Allocations (admin)",
      "item": [
        {
          "name": "Create Allocation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"vehicle_id\": {{vehicle_id}},\n  \"driver_id\": {{driver_id}},\n  \"allocation_date\": \"2026-06-10\"\n}" },
            "url": { "raw": "{{base_url}}/api/v1/allocations", "host": ["{{base_url}}"], "path": ["api", "v1", "allocations"] },
            "description": "Allocates a vehicle to a driver for a date and auto-creates a SCHEDULED shift. A vehicle/driver can have only ONE active allocation per date — a conflict returns 409."
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"vehicle_id\": 1,\n  \"driver_id\": 1,\n  \"allocation_date\": \"2026-06-10\"\n}" },
                "url": { "raw": "{{base_url}}/api/v1/allocations", "host": ["{{base_url}}"], "path": ["api", "v1", "allocations"] }
              },
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"created_at\": \"2026-06-10T09:00:00Z\",\n  \"updated_at\": \"2026-06-10T09:00:00Z\",\n  \"vehicle_id\": 1,\n  \"driver_id\": 1,\n  \"allocation_date\": \"2026-06-10\",\n  \"status\": \"ACTIVE\"\n}"
            },
            {
              "name": "409 Conflict (vehicle already allocated)",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"vehicle_id\": 1,\n  \"driver_id\": 1,\n  \"allocation_date\": \"2026-06-10\"\n}" },
                "url": { "raw": "{{base_url}}/api/v1/allocations", "host": ["{{base_url}}"], "path": ["api", "v1", "allocations"] }
              },
              "status": "Conflict",
              "code": 409,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": {\n    \"code\": \"VEHICLE_ALREADY_ALLOCATED\",\n    \"message\": \"Vehicle is already allocated for this date\"\n  }\n}"
            }
          ]
        },
        {
          "name": "List Allocations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/allocations?allocation_date=2026-06-10&vehicle_id=&driver_id=",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "allocations"],
              "query": [
                { "key": "allocation_date", "value": "2026-06-10", "description": "Optional filter (YYYY-MM-DD)" },
                { "key": "vehicle_id", "value": "", "description": "Optional filter", "disabled": true },
                { "key": "driver_id", "value": "", "description": "Optional filter", "disabled": true }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Release Allocation",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{base_url}}/api/v1/allocations/{{allocation_id}}", "host": ["{{base_url}}"], "path": ["api", "v1", "allocations", "{{allocation_id}}"] },
            "description": "Releases (frees) the allocation. Returns 204 No Content. The vehicle becomes re-allocatable the same day."
          },
          "response": [
            {
              "name": "204 No Content",
              "originalRequest": {
                "method": "DELETE",
                "header": [],
                "url": { "raw": "{{base_url}}/api/v1/allocations/1", "host": ["{{base_url}}"], "path": ["api", "v1", "allocations", "1"] }
              },
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": ""
            }
          ]
        }
      ]
    },
    {
      "name": "Orders (admin)",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"shift_id\": {{shift_id}},\n  \"destination_id\": {{destination_id}},\n  \"items\": [\n    { \"product_id\": {{product_id}}, \"quantity_gallons\": 500.00 }\n  ]\n}" },
            "url": { "raw": "{{base_url}}/api/v1/orders", "host": ["{{base_url}}"], "path": ["api", "v1", "orders"] },
            "description": "One order = one destination + >=1 items. Each item quantity must be > 0."
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"shift_id\": 1,\n  \"destination_id\": 2,\n  \"items\": [\n    { \"product_id\": 1, \"quantity_gallons\": 500.00 }\n  ]\n}" },
                "url": { "raw": "{{base_url}}/api/v1/orders", "host": ["{{base_url}}"], "path": ["api", "v1", "orders"] }
              },
              "status": "Created",
