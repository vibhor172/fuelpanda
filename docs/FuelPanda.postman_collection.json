          "name": "Create Location (Terminal destination)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Downtown Terminal\",\n  \"type\": \"TERMINAL\",\n  \"address\": \"42 Market St\",\n  \"latitude\": 40.7306,\n  \"longitude\": -73.9352\n}"
