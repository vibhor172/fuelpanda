            "description": "Liveness probe. Not under the /api/v1 prefix."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
