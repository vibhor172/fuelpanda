            "url": { "raw": "{{base_url}}/api/v1/locations/{{location_id}}", "host": ["{{base_url}}"], "path": ["api", "v1", "locations", "{{location_id}}"] },
            "description": "Partial update — send only the fields you want to change."
          },
          "response": []
