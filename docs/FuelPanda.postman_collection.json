          "name": "List Locations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/locations?limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "locations"],
              "query": [
                { "key": "limit", "value": "50", "description": "1–500" },
                { "key": "offset", "value": "0", "description": ">= 0" }
              ]
            }
          },
          "response": []
