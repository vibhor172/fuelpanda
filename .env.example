# Copy to .env for docker-compose / local runs.
DATABASE_URL=postgresql+psycopg2://fleetpanda:fleetpanda@db:5432/fleetpanda
REDIS_URL=redis://redis:6379/0
APP_ENV=local
LOG_LEVEL=INFO
INVENTORY_CACHE_TTL=60
ALLOC_LOCK_TTL=10
VEHICLE_LOCATION_TTL=3600
POSTGRES_USER=fleetpanda
POSTGRES_PASSWORD=fleetpanda
POSTGRES_DB=fleetpanda
